{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "HAL Simulation",
            "type": "debugpy",
            "request": "launch",
            "module": "host_abstraction.core.run_simulation",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Runtime: Daemon Engine",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "env": {
                "DEBUG_MODE": "true",
                "WAL_LOG_LEVEL": "VERBOSE"
            }
        },
        {
            "name": "Execution Engine: Attach to Process",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            }
        }
    ]
}